# 开发环境配置 - 本地开发时连接到远程 Home Assistant
# 复制此文件为 .env.local 并填入你的实际配置

# Home Assistant 地址（支持外网地址或内网穿透地址）
VITE_HA_URL=https://你的HA外网地址:8123

# Home Assistant 长期访问令牌
# 在 HA 中创建：用户资料 -> 长期访问令牌 -> 创建令牌
VITE_HA_TOKEN=your_long_lived_access_token_here

# 可选：后端 API 地址（如果有本地开发的后端服务）
# VITE_API_URL=http://localhost:8099
